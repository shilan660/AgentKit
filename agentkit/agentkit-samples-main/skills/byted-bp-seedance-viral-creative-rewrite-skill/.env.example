# Copy this file to .env and fill values locally.
# Do not paste secrets into chat, logs, or shared docs.

# BytePlus Ark key used only for Seedance video generation.
# Video understanding and rewrite planning are done by the host agent, not by ModelArk/Seed.
ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Seedance video generation
SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128
SEEDANCE_TASKS_PATH=/contents/generations/tasks
SEEDANCE_TIMEOUT_SEC=600
SEEDANCE_POLL_INTERVAL_SEC=2
SEEDANCE_AUDIO_SAFETY_RETRIES=1

# Local output. Keep this outside the skill folder so runs do not pollute the package source.
OUTPUT_DIR=../output
# Optional. Defaults to OUTPUT_DIR/cache.
VIRAL_REWRITE_CACHE_DIR=
# Optional debug artifacts. Disabled by default.
VIRAL_REWRITE_SHOW_DEBUG_ARTIFACTS=0
